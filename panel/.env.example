# ============================================================
#  PANEL + SİTE ORTAM DEĞİŞKENLERİ (PostgreSQL / Railway)
#  Bu dosyayı ".env" olarak kopyalayıp doldur (yerel geliştirme).
#  Railway'de değişkenler dashboard'dan girilir, .env kullanılmaz.
# ============================================================

# --- Veritabanı (PostgreSQL) ---
# Railway'de tek değişken yeter (Postgres servisine referans):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# Yerelde public proxy ile bağlanırken sonuna ?sslmode=require ekleyebilirsin.
DATABASE_URL=postgresql://postgres:parola@host:5432/railway

# (Alternatif: DATABASE_URL yerine ayrı ayrı)
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=parola
# PGDATABASE=railway
# DB_SSL=1            # public proxy / uzak bağlantıda SSL gerekiyorsa

# --- Panel girişi: db-kur/aktar bu parolayı "yoneticiler"e bcrypt'ler ---
ADMIN_SIFRE=tavaci123

# --- Oturum çerezi imzası (rastgele uzun bir değer ver) ---
OTURUM_ANAHTARI=degistir-bu-rastgele-olsun

# --- Panel/site portu (opsiyonel; Railway PORT'u kendi verir) ---
# PANEL_PORT=5174
