---
// ============================================================
//  KATEGORİ SAYFASI  (/menu/[kategori])
//  Bir kategorinin tüm ürünlerini görselli kartlar halinde listeler.
//  Her ürün kartı, ürünün detay sayfasına götürür.
//  SSR: kategori URL'den (Astro.params) bulunur, veri DB'den okunur.
// ============================================================

import Layout from "../../layouts/Layout.astro";
import { menuGetir } from "../../data/icerik.js";

const { kategori } = Astro.params;
const kategoriler = await menuGetir();
const kat = kategoriler.find((k) => k.slug === kategori);
if (!kat) return new Response(null, { status: 404, statusText: "Kategori bulunamadı" });
---

<Layout baslik={`${kat.kategori} | Tavacı Mehmet`} aciklama={`${kat.kategori} kategorisindeki tüm lezzetler.`}>
  <!-- Breadcrumb + başlık -->
  <section class="bg-white border-b border-black/5">
    <div class="max-w-6xl mx-auto px-4 py-10">
      <!-- Breadcrumb -->
      <nav class="text-sm text-koyu/50 flex items-center gap-2">
        <a href="/menu" class="hover:text-marka" data-i18n="nav.menu">Menü</a>
        <span>/</span>
        <span class="text-koyu/80" data-i18n-tr={kat.kategori} data-i18n-en={kat.kategoriEn}>{kat.kategori}</span>
      </nav>

      <div class="mt-4 flex items-center gap-3">
        <span class="text-4xl">{kat.ikon}</span>
        <div>
          <h1 class="font-baslik font-extrabold text-3xl md:text-4xl text-koyu" data-i18n-tr={kat.kategori} data-i18n-en={kat.kategoriEn}>{kat.kategori}</h1>
          <p class="text-koyu/50 text-sm mt-1">
            {kat.urunler.length} <span data-i18n="menu.items">ürün</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ürün kartları (detaya götürür) -->
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        kat.urunler.map((urun, i) => (
          <a
            href={`/menu/${kat.slug}/${urun.slug}`}
            class="group bg-white rounded-2xl overflow-hidden border border-black/5 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col"
            data-aos="fade-up"
            data-aos-delay={(i % 3) * 100}
          >
            {urun.gorsel && (
              <div class="overflow-hidden">
                <img
                  src={urun.gorsel}
                  alt={urun.ad}
                  loading="lazy"
                  class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            <div class="p-5 flex flex-col flex-1">
              <h3 class="font-semibold text-koyu leading-snug group-hover:text-marka transition-colors" data-i18n-tr={urun.ad} data-i18n-en={urun.adEn}>{urun.ad}</h3>
              {urun.aciklama && (
                <p class="mt-1.5 text-sm text-koyu/55 line-clamp-2" data-i18n-tr={urun.aciklama} data-i18n-en={urun.aciklamaEn}>{urun.aciklama}</p>
              )}
              <div class="mt-4 pt-3 border-t border-black/5 flex items-center justify-between gap-2">
                <span class="font-bold text-marka text-lg">{urun.fiyat}</span>
                <button
                  data-ad={urun.ad}
                  data-fiyat={urun.fiyat}
                  onclick="event.preventDefault();event.stopPropagation();sepeteEkle(this.dataset)"
                  data-i18n="cart.add"
                  class="text-xs font-semibold bg-marka text-white px-3 py-1.5 rounded-full hover:bg-marka-koyu transition-colors whitespace-nowrap"
                >
                  Sepete Ekle
                </button>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
