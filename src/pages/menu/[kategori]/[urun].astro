---
// ============================================================
//  ÜRÜN DETAY SAYFASI  (/menu/[kategori]/[urun])
//  Tavuk Dünyası ürün detayı tarzında:
//   - Breadcrumb + büyük görsel + ad/fiyat/açıklama + sipariş
//   - "İçinde Neler Var?", besin değerleri, alerjenler (temsilî)
//   - "Yanına Ne Gider?" (içecek + tatlı önerisi)
//   - "Benzer Ürünler" (aynı kategoriden)
//  SSR: kategori/ürün URL'den (Astro.params) bulunur, veri DB'den.
// ============================================================

import Layout from "../../../layouts/Layout.astro";
import { menuGetir, ayarlarGetir } from "../../../data/icerik.js";

const { kategori, urun: urunSlug } = Astro.params;
const kategoriler = await menuGetir();
const kat = kategoriler.find((k) => k.slug === kategori);
const urun = kat?.urunler.find((u) => u.slug === urunSlug);
if (!kat || !urun) return new Response(null, { status: 404, statusText: "Ürün bulunamadı" });

// "Yanına ne gider" önerileri: bir içecek + bir tatlı
const kucult = (s) => (s || "").toLocaleLowerCase("tr");
const icecekKat = kategoriler.find((k) => kucult(k.kategori).includes("içecek"));
const tatliKat = kategoriler.find((k) => kucult(k.kategori).includes("tatlı"));
const oneriHam = [];
if (icecekKat) oneriHam.push(icecekKat.urunler.find((u) => u.gorsel) || icecekKat.urunler[0]);
if (tatliKat) oneriHam.push(tatliKat.urunler.find((u) => u.gorsel) || tatliKat.urunler[0]);
const oneri = oneriHam.filter((o) => o && o.slug !== urun.slug);

// Aynı kategoriden, görselli, kendisi olmayan 4 benzer ürün
const benzer = kat.urunler.filter((u) => u.slug !== urun.slug && u.gorsel).slice(0, 4);

// "Sipariş Ver" hedefi (panelde sipariş linki varsa oraya)
const ayarlar = await ayarlarGetir();
const siparisHedef = ayarlar.siparisLinki || "/iletisim";
const siparisDis = siparisHedef.startsWith("http");

// Besin değerleri temsilîdir (gerçek veri yok). Ürüne göre biraz
// değişsin diye ada bağlı basit bir türetme yapıyoruz.
const tohum = urun.ad.length;
const besin = {
  kalori: 380 + (tohum % 9) * 30, // ~380-620
  protein: 22 + (tohum % 7) * 3,
  karbonhidrat: 28 + (tohum % 6) * 4,
  yag: 16 + (tohum % 5) * 3,
};
---

<Layout baslik={`${urun.ad} | Tavacı Mehmet`} aciklama={urun.aciklama || urun.ad}>
  <!-- Breadcrumb -->
  <section class="bg-white border-b border-black/5">
    <div class="max-w-5xl mx-auto px-4 py-5">
      <nav class="text-sm text-koyu/50 flex items-center gap-2 flex-wrap">
        <a href="/menu" class="hover:text-marka" data-i18n="nav.menu">Menü</a>
        <span>/</span>
        <a href={`/menu/${kat.slug}`} class="hover:text-marka" data-i18n-tr={kat.kategori} data-i18n-en={kat.kategoriEn}>{kat.kategori}</a>
        <span>/</span>
        <span class="text-koyu/80" data-i18n-tr={urun.ad} data-i18n-en={urun.adEn}>{urun.ad}</span>
      </nav>
    </div>
  </section>

  <!-- ÜST: görsel + bilgi -->
  <section class="max-w-5xl mx-auto px-4 py-10 grid md:grid-cols-2 gap-10 items-center">
    <!-- Görsel (sabit kare oran - görsel ne olursa olsun düzgün dursun) -->
    <div class="rounded-3xl overflow-hidden bg-white border border-black/5 shadow-sm max-w-sm w-full mx-auto" data-aos="fade-right">
      {urun.gorsel ? (
        <img src={urun.gorsel} alt={urun.ad} class="w-full aspect-square object-cover" />
      ) : (
        <div class="aspect-square bg-gradient-to-br from-altin/30 to-marka/20 flex items-center justify-center text-[8rem]">
          🍗
        </div>
      )}
    </div>

    <!-- Bilgi -->
    <div data-aos="fade-left">
      <span class="text-sm font-semibold text-altin uppercase tracking-wide" data-i18n-tr={kat.kategori} data-i18n-en={kat.kategoriEn}>{kat.kategori}</span>
      <h1 class="mt-2 font-baslik font-extrabold text-3xl md:text-4xl text-koyu" data-i18n-tr={urun.ad} data-i18n-en={urun.adEn}>{urun.ad}</h1>
      {urun.aciklama && (
        <p class="mt-4 text-koyu/70 leading-relaxed" data-i18n-tr={urun.aciklama} data-i18n-en={urun.aciklamaEn}>{urun.aciklama}</p>
      )}

      <div class="mt-6 flex items-center gap-4 flex-wrap">
        <span class="font-baslik font-extrabold text-3xl text-marka">{urun.fiyat}</span>
        <button
          data-ad={urun.ad}
          data-fiyat={urun.fiyat}
          onclick="sepeteEkle(this.dataset)"
          data-i18n="cart.add"
          class="bg-marka hover:bg-marka-koyu text-white font-semibold px-8 py-3.5 rounded-full transition-colors"
        >
          Sepete Ekle
        </button>
        <a href={siparisHedef} target={siparisDis ? "_blank" : undefined} rel={siparisDis ? "noopener" : undefined} class="text-sm font-semibold text-koyu/60 hover:text-marka underline underline-offset-4">
          Yemeksepeti'nden sipariş
        </a>
      </div>

      <!-- Alerjenler (temsilî) -->
      <div class="mt-8">
        <h3 class="font-semibold text-koyu text-sm mb-2 flex items-center gap-2">
          <span data-i18n="detail.allergens">Alerjenler</span>
          <span class="text-[10px] font-normal text-koyu/40" data-i18n="detail.sample">Temsilî bilgidir</span>
        </h3>
        <div class="flex flex-wrap gap-2 text-xs">
          <span class="bg-koyu/5 px-3 py-1.5 rounded-full" data-i18n="alrj.gluten">Gluten</span>
          <span class="bg-koyu/5 px-3 py-1.5 rounded-full" data-i18n="alrj.milk">Süt</span>
          <span class="bg-koyu/5 px-3 py-1.5 rounded-full" data-i18n="alrj.egg">Yumurta</span>
        </div>
      </div>
    </div>
  </section>

  <!-- İÇİNDEKİLER + BESİN DEĞERLERİ -->
  <section class="bg-white py-12">
    <div class="max-w-5xl mx-auto px-4 grid md:grid-cols-2 gap-10">
      <!-- İçinde neler var -->
      <div data-aos="fade-up">
        <h2 class="font-baslik font-extrabold text-2xl text-koyu">
          <span data-i18n="detail.ingredients">İçinde Neler Var?</span>
        </h2>
        <p class="mt-4 text-koyu/70 leading-relaxed" data-i18n="detail.ingText">
          Taze malzemeler, özel baharatlar ve közün eşsiz lezzetiyle hazırlanır.
        </p>
      </div>

      <!-- Besin değerleri (temsilî) -->
      <div data-aos="fade-up" data-aos-delay="100">
        <h2 class="font-baslik font-extrabold text-2xl text-koyu flex items-center gap-2">
          <span data-i18n="detail.nutrition">Besin Değerleri</span>
          <span class="text-[10px] font-normal text-koyu/40" data-i18n="detail.sample">Temsilî bilgidir</span>
        </h2>
        <div class="mt-4 grid grid-cols-2 gap-3">
          <div class="bg-krem rounded-xl px-4 py-3 flex justify-between">
            <span class="text-koyu/60 text-sm" data-i18n="nut.cal">Kalori</span>
            <span class="font-bold text-marka">{besin.kalori} kcal</span>
          </div>
          <div class="bg-krem rounded-xl px-4 py-3 flex justify-between">
            <span class="text-koyu/60 text-sm" data-i18n="nut.protein">Protein</span>
            <span class="font-bold text-marka">{besin.protein} g</span>
          </div>
          <div class="bg-krem rounded-xl px-4 py-3 flex justify-between">
            <span class="text-koyu/60 text-sm" data-i18n="nut.carb">Karbonhidrat</span>
            <span class="font-bold text-marka">{besin.karbonhidrat} g</span>
          </div>
          <div class="bg-krem rounded-xl px-4 py-3 flex justify-between">
            <span class="text-koyu/60 text-sm" data-i18n="nut.fat">Yağ</span>
            <span class="font-bold text-marka">{besin.yag} g</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- YANINA NE GİDER? -->
  {
    oneri.length > 0 && (
      <section class="max-w-5xl mx-auto px-4 py-12">
        <h2 class="font-baslik font-extrabold text-2xl text-koyu mb-6" data-i18n="detail.pairing">Yanına Ne Gider?</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {oneri.map((o) => (
            <a href={`/menu/${o.katSlug}/${o.slug}`} class="group flex items-center gap-3 bg-white rounded-xl border border-black/5 shadow-sm hover:shadow-md hover:border-marka/30 p-2.5 transition">
              {o.gorsel && <img src={o.gorsel} alt={o.ad} loading="lazy" class="w-14 h-14 rounded-lg object-cover shrink-0" />}
              <div class="min-w-0">
                <h3 class="text-sm font-semibold text-koyu truncate group-hover:text-marka transition-colors" data-i18n-tr={o.ad} data-i18n-en={o.adEn}>{o.ad}</h3>
                <span class="text-marka font-bold text-sm">{o.fiyat}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- BENZER ÜRÜNLER -->
  {
    benzer.length > 0 && (
      <section class="bg-white py-12">
        <div class="max-w-5xl mx-auto px-4">
          <h2 class="font-baslik font-extrabold text-2xl text-koyu mb-6" data-i18n="detail.related">Benzer Ürünler</h2>
          <div class="grid gap-5 grid-cols-2 lg:grid-cols-4">
            {benzer.map((u) => (
              <a href={`/menu/${kat.slug}/${u.slug}`} class="group bg-krem rounded-2xl overflow-hidden border border-black/5 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                {u.gorsel && (
                  <div class="overflow-hidden">
                    <img src={u.gorsel} alt={u.ad} loading="lazy" class="w-full h-32 object-cover group-hover:scale-105 transition-transform duration-500" />
                  </div>
                )}
                <div class="p-3">
                  <h3 class="text-sm font-semibold text-koyu leading-snug line-clamp-2 group-hover:text-marka transition-colors" data-i18n-tr={u.ad} data-i18n-en={u.adEn}>{u.ad}</h3>
                  <span class="text-marka font-bold text-sm">{u.fiyat}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</Layout>
