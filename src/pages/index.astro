---
// ============================================================
//  ANASAYFA
//  Hero (giriş) bölümü, öne çıkan ürünler, hakkımızda özeti
//  ve çağrı (CTA) bölümünden oluşur.
// ============================================================

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import BolumlerNav from "../components/BolumlerNav.astro";
import { ayarlarGetir, anasayfaGetir } from "../data/icerik.js";

// Instagram adresi + anasayfa bölüm görünürlüğü panelden gelir
const ayarlar = await ayarlarGetir();
const { bolumler, hikaye, cta, instagram } = await anasayfaGetir();

// "Sipariş Ver" hedefi: panelde sipariş linki varsa oraya (Yemeksepeti vb.),
// yoksa CTA linkine. Dış linkse yeni sekmede açılsın.
const siparisHedef = ayarlar.siparisLinki || cta.link || "/iletisim";
const siparisDis = siparisHedef.startsWith("http");

// Instagram @kullanıcı adını panel Ayarlar'daki adresten türet
// (ör. https://instagram.com/tavacimehmetefendiii/ -> @tavacimehmetefendiii).
const igKullanici = (ayarlar.instagram || "").replace(/\/+$/, "").split("/").pop() || "";
const igEtiket = igKullanici ? "@" + igKullanici.replace(/^@/, "") : "";
---

<Layout baslik="Tavacı Mehmet | Közde Pişen Tavalar" aciklama="Geleneksel tava lezzetleri, közün dumanıyla buluşuyor.">
  <!-- ===================== HERO SLIDER ===================== -->
  {bolumler.hero && <Hero />}

  <!-- ===== BÖLÜM YÖNLENDİRME PANELLERİ (her sekmeye animasyonlu kart) ===== -->
  {bolumler.kesfet && <BolumlerNav />}

  <!-- ===================== HAKKIMIZDA ÖZETİ ===================== -->
  {bolumler.hikaye && (
  <section class="bg-white py-16 overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-10 items-center">
      <div class="text-7xl text-center" data-aos="zoom-in">{hikaye.emoji}</div>
      <div data-aos="fade-left">
        <h2 class="font-baslik font-extrabold text-3xl text-koyu" data-i18n="home.story.title">Hikayemiz</h2>
        <p class="mt-4 text-koyu/70 leading-relaxed" data-i18n="home.story.text">
          Tavacı Mehmet, küçük bir mahalle lokantası olarak 1998'de yola çıktı.
          Bugün dört şehirde, aynı geleneksel köz lezzetini binlerce misafirimizle
          paylaşıyoruz. Sırrımız basit: taze malzeme, gerçek köz ateşi ve sabır.
        </p>
        <a href={hikaye.link} class="inline-block mt-6 text-marka font-semibold hover:underline" data-i18n="home.story.more">
          Daha fazlasını oku →
        </a>
      </div>
    </div>
  </section>
  )}

  <!-- ===================== INSTAGRAM ===================== -->
  {bolumler.instagram && (
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="text-center mb-10" data-aos="fade-up">
      <h2 class="font-baslik font-extrabold text-3xl md:text-4xl text-koyu" data-i18n="home.ig.title">Bizi Takip Et</h2>
      <a
        href={ayarlar.instagram}
        target="_blank"
        rel="noopener"
        class="mt-2 inline-block text-marka font-semibold hover:underline"
      >
        {igEtiket}
      </a>
    </div>

    <!-- Ortada tek görsel (panelden yüklenir) — tıklayınca Instagram'a gider.
         Görsel yoksa hiç gösterilmez (kırık kare çıkmaz). -->
    {instagram.gorsel && (
      <a
        href={ayarlar.instagram}
        target="_blank"
        rel="noopener"
        class="group block max-w-md mx-auto"
        data-aos="zoom-in"
      >
        <div class="relative aspect-square rounded-2xl overflow-hidden bg-koyu/5 shadow-sm">
          <img src={instagram.gorsel} alt="Tavacı Mehmet Instagram" loading="lazy" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
          <span class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors flex items-center justify-center opacity-0 group-hover:opacity-100">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="w-12 h-12 text-white drop-shadow">
              <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.13 1.38C1.35 2.68.94 3.35.63 4.14.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.72 1.46 1.38 2.13.67.66 1.34 1.07 2.13 1.38.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.79-.31 1.46-.72 2.13-1.38.66-.67 1.07-1.34 1.38-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91-.31-.79-.72-1.46-1.38-2.13-.67-.66-1.34-1.07-2.13-1.38-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0z"/>
              <path d="M12 5.84A6.16 6.16 0 1 0 18.16 12 6.16 6.16 0 0 0 12 5.84M12 16a4 4 0 1 1 4-4 4 4 0 0 1-4 4z"/>
              <circle cx="18.41" cy="5.59" r="1.44"/>
            </svg>
          </span>
        </div>
      </a>
    )}
  </section>
  )}

  <!-- ===================== ÇAĞRI (CTA) ===================== -->
  {bolumler.cta && (
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="bg-marka rounded-3xl px-8 py-12 text-center text-white" data-aos="zoom-in">
      <h2 class="font-baslik font-extrabold text-3xl" data-i18n="home.cta.title">Bugün canınız köz mü çekti?</h2>
      <p class="mt-3 text-white/80" data-i18n="home.cta.sub">Hemen sipariş verin, sıcak sıcak kapınızda.</p>
      <a href={siparisHedef} target={siparisDis ? "_blank" : undefined} rel={siparisDis ? "noopener" : undefined} class="inline-block mt-7 bg-white text-marka font-bold px-8 py-3.5 rounded-full hover:bg-krem transition-colors" data-i18n="home.cta.btn">
        Sipariş Ver
      </a>
    </div>
  </section>
  )}
</Layout>
