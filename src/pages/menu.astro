---
// ============================================================
//  MENÜ ANA SAYFASI (Tavuk Dünyası "lezzetler" tarzı)
//  Sadece görselli KATEGORİ KARTLARI ızgarası gösterir.
//  Her kart, o kategorinin kendi sayfasına götürür:
//    /menu/[kategori-slug]
// ============================================================

import Layout from "../layouts/Layout.astro";
import { menuGetir, kapak } from "../data/icerik.js";

// Panelden (Sanity) veya yerel yedekten menüyü al
const kategoriler = await menuGetir();
---

<Layout baslik="Menü | Tavacı Mehmet" aciklama="Tavada beyaz etler, makarnalar, sokak lezzetleri ve daha fazlası.">
  <!-- Sayfa başlığı -->
  <section class="bg-white border-b border-black/5">
    <div class="max-w-6xl mx-auto px-4 py-14 text-center">
      <h1 class="font-baslik font-extrabold text-4xl md:text-5xl text-koyu" data-i18n="menu.title">Menümüz</h1>
      <p class="mt-3 text-koyu/60" data-i18n="menu.intro">
        Kategorilere tıklayarak lezzetlerimizi keşfet ve sipariş ver
      </p>
    </div>
  </section>

  <!-- ===================== KATEGORİ KARTLARI IZGARASI ===================== -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid gap-5 grid-cols-2 lg:grid-cols-3">
      {
        kategoriler.map((kat, i) => (
          <a
            href={`/menu/${kat.slug}`}
            class="kat-kart group relative block h-48 md:h-60 rounded-2xl overflow-hidden shadow-sm"
            data-aos="fade-up"
            data-aos-delay={(i % 3) * 80}
          >
            <!-- Kapak görseli (yoksa degrade) -->
            {kapak(kat) ? (
              <img
                src={kapak(kat)}
                alt={kat.kategori}
                loading="lazy"
                class="kat-bg absolute inset-0 w-full h-full object-cover"
              />
            ) : (
              <div class="kat-bg absolute inset-0 bg-gradient-to-br from-marka to-marka-koyu" />
            )}

            <!-- Karartma (yazılar okunsun) -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 group-hover:from-black/85 transition-colors" />

            <!-- İçerik -->
            <div class="absolute inset-0 p-4 md:p-5 flex flex-col justify-between text-white">
              <span class="text-3xl drop-shadow">{kat.ikon}</span>
              <div>
                <h3
                  class="font-baslik font-extrabold text-lg md:text-xl leading-tight drop-shadow"
                  data-i18n-tr={kat.kategori}
                  data-i18n-en={kat.kategoriEn}
                >
                  {kat.kategori}
                </h3>
                <div class="mt-1 flex items-center justify-between">
                  <span class="text-xs text-white/80">
                    {kat.urunler.length} <span data-i18n="menu.items">ürün</span>
                  </span>
                  <span class="text-xs font-semibold text-altin inline-flex items-center gap-1">
                    <span data-i18n="menu.viewCat">İncele</span>
                    <span class="transition-transform group-hover:translate-x-1">→</span>
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  /* Kategori kartı: üzerine gelince kapak görseli yumuşakça yakınlaşsın */
  .kat-bg {
    transition: transform 0.5s ease;
  }
  .kat-kart:hover .kat-bg {
    transform: scale(1.08);
  }
</style>
