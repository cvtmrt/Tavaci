---
// ============================================================
//  FRANCHISE BAŞVURU SAYFASI
//  Franchise (bayilik) almak isteyenler formu doldurur; başvuru
//  siparişlerle AYNI şekilde kayıtlı WhatsApp numarasına hazır
//  mesaj olarak iletilir. Sunucu gerekmez.
// ============================================================

import Layout from "../layouts/Layout.astro";
import { ayarlarGetir } from "../data/icerik.js";

// Başvurunun gideceği WhatsApp numarası panelden gelir (siparişlerle aynı)
const ayarlar = await ayarlarGetir();
const waNumara = (ayarlar.whatsapp || "").replace(/[^0-9]/g, "");
---

<Layout baslik="Franchise Başvurusu | Tavacı Mehmet" aciklama="Tavacı Mehmet ailesine katılın. Franchise (bayilik) başvurunuzu hemen iletin.">
  <section class="max-w-6xl mx-auto px-4 py-16 grid md:grid-cols-2 gap-12">
    <!-- Sol: franchise tanıtımı -->
    <div>
      <h1 class="font-baslik font-extrabold text-4xl text-koyu" data-i18n="franchise.title">Franchise Fırsatı</h1>
      <p class="mt-4 text-koyu/70" data-i18n="franchise.sub">
        1998'den beri közün lezzetini taşıyan Tavacı Mehmet ailesine siz de katılın. Başvurunuzu doldurun, ekibimiz en kısa sürede sizinle iletişime geçsin.
      </p>

      <ul class="mt-8 space-y-5">
        <li class="flex items-start gap-3">
          <span class="text-2xl">🔥</span>
          <div>
            <div class="font-semibold text-koyu" data-i18n="franchise.benefit1.title">Kanıtlanmış Marka</div>
            <div class="text-koyu/60 text-sm" data-i18n="franchise.benefit1.text">1998'den beri güçlenen marka bilinirliği ve sadık müşteri kitlesi.</div>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-2xl">🤝</span>
          <div>
            <div class="font-semibold text-koyu" data-i18n="franchise.benefit2.title">Uçtan Uca Destek</div>
            <div class="text-koyu/60 text-sm" data-i18n="franchise.benefit2.text">Lokasyon seçimi, kurulum, eğitim ve operasyonda yanınızdayız.</div>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-2xl">📈</span>
          <div>
            <div class="font-semibold text-koyu" data-i18n="franchise.benefit3.title">Kârlı İş Modeli</div>
            <div class="text-koyu/60 text-sm" data-i18n="franchise.benefit3.text">Test edilmiş menü, standart reçeteler ve verimli işletme modeli.</div>
          </div>
        </li>
      </ul>
    </div>

    <!-- Sağ: franchise başvuru formu -->
    <div class="bg-white rounded-2xl p-8 border border-black/5 shadow-sm">
      <form id="franchise-formu" class="space-y-5" data-wa={waNumara}>
        <div>
          <label class="block text-sm font-medium text-koyu mb-1" for="f-ad" data-i18n="franchise.name">Ad Soyad</label>
          <input id="f-ad" name="ad" type="text" required
            class="w-full rounded-lg border border-black/10 px-4 py-2.5 focus:border-marka focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-koyu mb-1" for="f-tel" data-i18n="franchise.phone">Telefon</label>
          <input id="f-tel" name="telefon" type="tel" required
            class="w-full rounded-lg border border-black/10 px-4 py-2.5 focus:border-marka focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-koyu mb-1" for="f-eposta" data-i18n="franchise.email">E-posta</label>
          <input id="f-eposta" name="eposta" type="email"
            class="w-full rounded-lg border border-black/10 px-4 py-2.5 focus:border-marka focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-koyu mb-1" for="f-sehir" data-i18n="franchise.city">Şube Açmak İstediğiniz Şehir</label>
          <input id="f-sehir" name="sehir" type="text" required
            class="w-full rounded-lg border border-black/10 px-4 py-2.5 focus:border-marka focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-koyu mb-1" for="f-mesaj" data-i18n="franchise.message">İş Deneyiminiz / Notunuz</label>
          <textarea id="f-mesaj" name="mesaj" rows="4"
            class="w-full rounded-lg border border-black/10 px-4 py-2.5 focus:border-marka focus:outline-none"></textarea>
        </div>
        <button type="submit"
          class="w-full bg-[#25D366] hover:brightness-105 text-white font-semibold py-3 rounded-full transition">
          <span data-i18n="franchise.send">WhatsApp ile Başvuru Gönder</span>
        </button>

        <!-- Başvuru iletilince burada teşekkür mesajı görünür -->
        <p id="f-tesekkur" data-i18n="franchise.thanks" class="hidden text-center text-green-700 font-medium">
          Başvurunuz alındı! En kısa sürede sizinle iletişime geçeceğiz. 🎉
        </p>
        <p class="text-xs text-center text-koyu/50" data-i18n="franchise.note">
          Başvurunuz WhatsApp üzerinden iletilir.
        </p>
      </form>
    </div>
  </section>
</Layout>

<script>
  // Form gönderimini yakala: sayfa yenilenmesin, başvuru WhatsApp'tan
  // kayıtlı numaraya hazır mesaj olarak iletilsin (sipariş akışıyla aynı).
  // astro:page-load ile her sayfa geçişinde yeniden bağlanır (View Transitions).
  function franchiseBagla() {
    const form = document.getElementById("franchise-formu") as HTMLFormElement | null;
    const tesekkur = document.getElementById("f-tesekkur");
    if (!form || form.dataset.bagli) return; // çift bağlamayı önle
    form.dataset.bagli = "1";
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const wa = form.dataset.wa;
      const ad = (document.getElementById("f-ad") as HTMLInputElement)?.value || "";
      const tel = (document.getElementById("f-tel") as HTMLInputElement)?.value || "";
      const eposta = (document.getElementById("f-eposta") as HTMLInputElement)?.value || "";
      const sehir = (document.getElementById("f-sehir") as HTMLInputElement)?.value || "";
      const mesaj = (document.getElementById("f-mesaj") as HTMLTextAreaElement)?.value || "";
      if (!wa) { alert("WhatsApp numarası tanımlı değil (panel > Ayarlar)."); return; }
      const metin =
        `*Yeni Franchise Başvurusu — Tavacı Mehmet*\n\n` +
        `👤 Ad Soyad: ${ad}\n` +
        `📞 Telefon: ${tel}` +
        (eposta ? `\n✉️ E-posta: ${eposta}` : "") +
        `\n🏙️ İlgilenilen Şehir: ${sehir}` +
        (mesaj ? `\n📝 Not: ${mesaj}` : "");
      window.open(`https://wa.me/${wa}?text=${encodeURIComponent(metin)}`, "_blank");
      form.reset();
      tesekkur?.classList.remove("hidden"); // teşekkür mesajını göster
    });
  }
  franchiseBagla();
  document.addEventListener("astro:page-load", franchiseBagla);
</script>
